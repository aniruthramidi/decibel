{
  "buildCommand": "cd decibel-web && npm install && npm run build",
  "outputDirectory": "decibel-web/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
